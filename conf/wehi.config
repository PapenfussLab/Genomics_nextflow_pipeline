
params {
    config_profile_description = 'Walter and Eliza Hall Institute (WEHI) Milton HPC cluster profile'
    config_profile_contact     = 'Jacob Munro (munro.j@wehi.edu.au)'
    config_profile_url         = "https://www.wehi.edu.au/"
    max_memory                 = 1.3.TB
    max_cpus                   = 128
    max_time                   = 48.h

    // system specific default output directory
    output_dir         = "/vast/scratch/users/${System.getenv('USER')}/cnvkit_output"

}

process {
    resourceLimits = [
        memory: 1.3.TB,
        cpus: 128,
        time: 48.h
    ]
    executor = 'slurm'
    cache    = 'lenient'
}

executor {
    queueSize         = 100
    queueStatInterval = '10 sec'
    pollInterval      = '10 sec'
    submitRateLimit   = '10 sec'
}


singularity {
   enabled    = false
   autoMounts = true
   runOptions = '-B /vast -B /stornext'
}


apptainer {
    enabled = true
    autoMounts = true
    cacheDir = "/vast/scratch/users/${System.getenv('USER')}/nextflow/singularity_cache"
    runOptions = '-B /vast -B /stornext'
}

cleanup = true
profiles {
    debug {
        cleanup = false
    }
}

