params {
    // original params
    metadata  = null    
    refDir    = null
    outDir    = null
    facetsuite = null
    genome    = "GRCh38"

    // these are parameters for FACETS only
    facets_cval_preproc = 25
    facets_window = 250
    facets_cval = 200


    // -----------------------------------
    start_from = "fastq" // default 




    // input
    samplesheet = null

    // containers
    containers_dir = null

    // reference genome parameters
    ref_fasta = null 
    bwamem2_index = null
    vep_cache = null

    // 
    dnaseq_type = "WES" // WGS, WES, panel (capture) or amplicon
    target_bed = null // needed only for WES and panels

    // has_umi = false 
    // umi_info = null  // specify how to read UMI

}









profiles { 
    local { 
        process.executor = 'local' 
        params.containers_dir = ""
    }
    // HPC env
    wehi {
        includeConfig 'conf/wehi.config'
    }

    // genome
    hg38 {
        includeConfig 'conf/genomes/hg38.config'
    }

    // genome
    mm10 {
        includeConfig 'conf/genomes/mm10.config'
    }



    // TRACKER-specific stuff
    tracker {
        params.RG_LB = "TRACKER"
    }


}







process {
  withLabel: samtools_8 {
    container = "${params.containers_dir}/genomicsGeneral.sif"
    cpus = 8
    memory = 16.GB
    time = 48.hour
  }

  withLabel: samtools_4 {
    container = "${params.containers_dir}/genomicsGeneral.sif"
    cpus = 4
    memory = 8.GB
    time = 24.hour
  }

  withLabel: samtools_2 {
    container = "${params.containers_dir}/genomicsGeneral.sif"
    cpus = 2
    memory = 4.GB
    time = 12.hour
  }

  withLabel: samtools_1 {
    container = "${params.containers_dir}/genomicsGeneral.sif"
    cpus = 1
    memory = 2.GB
    time = 12.hour
  }

  withName: BWA_MEM2_ALIGN {
    container = "${params.containers_dir}/genomicsGeneral.sif"
    cpus = 16
    memory = 20.GB
    time = 48.hour
  }















  // these are the original processes
  withName: bwa_mem {
    cpus = 20
    memory = 16.GB
    time = 48.hour
  }

  withName: markduplicate {     
    cpus = 2
    memory = 36.GB
    time = 48.hour
  }

  withName: QC_metrics {     
    cpus = 2
    memory = 8.GB
    time = 48.hour
  }

  withName: mutect2 {     
    cpus = 8
    memory = 64.GB
    time = 48.hour
  }

  withName: haplotypecaller {
    cpus = 8
    memory = 64.GB
    time = 48.hour
  }

  withName: snp_pileup {
    cpus = 1
    memory = 2.GB
    time = 48.hour
  }

  withName: facets {
    cpus = 1
    memory = 8.GB
    time = 48.hour
  }

}